# Root app defaults used by shared scripts.
NODE_ENV=development

# Backend
PORT=5001
CLIENT_URL=http://localhost:3000
API_BASE_URL=http://localhost:5001
MONGODB_URI=mongodb://127.0.0.1:27017/medilink
JWT_SECRET=replace-with-64-byte-random-hex
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Realtime
REALTIME_PORT=5002
REALTIME_SERVER_URL=http://localhost:5002
REALTIME_INTERNAL_SECRET=replace-with-random-realtime-bridge-secret

# Email
DISABLE_EMAIL=false
EMAIL_REQUIRED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user@example.com
EMAIL_PASS=your-smtp-password-or-app-password
EMAIL_FROM="Medilink Health Care <your-smtp-user@example.com>"
EMAIL_CONNECTION_TIMEOUT_MS=8000
EMAIL_GREETING_TIMEOUT_MS=8000
EMAIL_SOCKET_TIMEOUT_MS=10000

# Frontend
VITE_API_URL=http://localhost:5001/api
VITE_REALTIME_URL=http://localhost:5002
VITE_SOCKET_TRANSPORTS=websocket
VITE_KEEPALIVE_ENABLED=true
VITE_KEEPALIVE_INTERVAL_MS=240000
VITE_KEEPALIVE_TIMEOUT_MS=8000

# Android
EXPO_PUBLIC_API_URL=http://10.0.2.2:5001/api
EXPO_PUBLIC_REALTIME_URL=http://10.0.2.2:5002
